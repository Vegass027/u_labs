# ============================================================
# Environment
# ============================================================
NODE_ENV=development
PORT=3001
API_URL=http://localhost:3001
WEB_URL=http://localhost:3000

# ============================================================
# Database (PostgreSQL)
# ============================================================
# Для Supabase: получить в Settings → Database → Connection string → URI
# Для локальной PostgreSQL: postgresql://postgres:postgres@localhost:5432/agency_db
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.your-project.supabase.co:5432/postgres

# ============================================================
# Supabase (База данных в облаке)
# ============================================================
# Получить в https://supabase.com/dashboard → Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ============================================================
# JWT Auth (JWT токены для авторизации)
# ============================================================
# Генерировать: openssl rand -hex 64 (сгенерировать два разных секрета)
JWT_ACCESS_SECRET=your-super-secret-access-key-min-32-chars
JWT_REFRESH_SECRET=your-super-secret-refresh-key-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# ============================================================
# OpenAI (AI функции: Whisper + GPT-4o)
# ============================================================
# Получить в https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key

# ============================================================
# Telegram Bot (Уведомления в Telegram)
# ============================================================
# Получить у @BotFather в Telegram
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
# Секрет для webhook валидации (любая случайная строка)
TELEGRAM_WEBHOOK_SECRET=your-webhook-secret

# ============================================================
# CORS (Разрешённые источники запросов)
# ============================================================
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ============================================================
# Next.js Public Variables (для web - доступны в браузере)
# ============================================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
NEXT_PUBLIC_API_URL=http://localhost:3001
